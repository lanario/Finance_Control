# Supabase - Financeiro Pessoal
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase - Financeiro Empresarial (opcional)
NEXT_PUBLIC_SUPABASE_EMPRESARIAL_URL=
NEXT_PUBLIC_SUPABASE_EMPRESARIAL_ANON_KEY=

# Supabase Service Role (OBRIGATÓRIO para checkout e webhooks de assinatura)
# Onde pegar: Supabase Dashboard > seu projeto Pessoal > Project Settings > API > "service_role" (secret)
SUPABASE_PESSOAL_SERVICE_ROLE_KEY=
# Empresarial: Supabase Dashboard (projeto empresarial) > Project Settings > API > service_role
SUPABASE_EMPRESARIAL_SERVICE_ROLE_KEY=
# Se usar um único projeto: SUPABASE_SERVICE_ROLE_KEY= (pessoal usa isso como fallback)

# Stripe (obrigatório para checkout e webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Preço assinatura R$ 30/mês - Pessoal
STRIPE_PRICE_ID=price_...
# Preço assinatura R$ 30/mês - Empresarial (produto/preço separado no Stripe)
STRIPE_PRICE_ID_EMPRESARIAL=price_...
# Preço assinatura Plano Infinity (pessoal + empresarial juntos)
STRIPE_PRICE_ID_INFINITY=price_...

# Opcional: URL base do site (para success/cancel do Checkout)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
